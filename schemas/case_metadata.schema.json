{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdw.ai/schemas/case_metadata.schema.json",
  "title": "CaseMetadataArtifact",
  "allOf": [
    { "$ref": "./_common.definitions.json#/$defs/artifactEnvelope" },
    {
      "type": "object",
      "properties": {
        "artifact_type": { "const": "case_metadata" },
        "data": { "$ref": "#/$defs/caseMetadataData" }
      },
      "required": ["artifact_type", "data"]
    }
  ],
  "$defs": {
    "caseMetadataData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "display_name",
        "workflow",
        "version",
        "target",
        "indication",
        "sources",
        "limits"
      ],
      "properties": {
        "case_id": { "$ref": "./_common.definitions.json#/$defs/caseId" },
        "display_name": { "type": "string", "minLength": 1 },
        "workflow": { "const": "translational_diligence" },
        "version": { "type": "string", "minLength": 1 },
        "target": { "$ref": "./_common.definitions.json#/$defs/namedEntity" },
        "indication": { "$ref": "./_common.definitions.json#/$defs/namedEntity" },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pubmed",
            "clinicaltrials",
            "opentargets",
            "chembl",
            "biothings",
            "uniprot",
            "reactome",
            "gwas",
            "pharmgkb",
            "openfda",
            "local_docs"
          ],
          "properties": {
            "pubmed": { "type": "boolean" },
            "clinicaltrials": { "type": "boolean" },
            "opentargets": { "type": "boolean" },
            "chembl": { "type": "boolean" },
            "biothings": { "type": "boolean" },
            "uniprot": { "type": "boolean" },
            "reactome": { "type": "boolean" },
            "gwas": { "type": "boolean" },
            "pharmgkb": { "type": "boolean" },
            "openfda": { "type": "boolean" },
            "octagon_market": { "type": "boolean" },
            "local_docs": { "type": "boolean" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_literature_records",
            "max_trials",
            "max_evidence_rows"
          ],
          "properties": {
            "max_literature_records": { "type": "integer", "minimum": 1 },
            "max_trials": { "type": "integer", "minimum": 1 },
            "max_evidence_rows": { "type": "integer", "minimum": 1 }
          }
        },
        "run_mode_defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fixture_allowed": { "type": "boolean" },
            "live_allowed": { "type": "boolean" }
          }
        },
        "input_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "biology": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mechanism_direction": { "type": ["string", "null"] },
                "modality": { "type": ["string", "null"] },
                "target_alias": { "type": ["string", "null"] }
              }
            },
            "disease": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "patient_segment": { "type": ["string", "null"] },
                "geography": { "type": ["string", "null"] }
              }
            },
            "program": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "asset": { "type": ["string", "null"] },
                "company": { "type": ["string", "null"] },
                "opportunity_type": { "type": ["string", "null"] },
                "slater_invested": { "type": ["boolean", "null"] },
                "development_stage": { "type": ["string", "null"] },
                "comparators": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "commercial": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "strategic_question": { "type": ["string", "null"] },
                "licensing_question": { "type": ["string", "null"] },
                "investment_question": { "type": ["string", "null"] }
              }
            }
          }
        },
        "benchmark": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "cohort": { "type": ["string", "null"] }
          }
        },
        "maturity_stage": { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_density": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "top_risk": { "type": "string" }
      }
    }
  }
}
