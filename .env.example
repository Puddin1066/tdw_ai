# Translational Diligence Workbench — environment template
# Copy to .env and fill in values for live mode only.
# Fixture mode must run without any of these keys.

# Build-time synthesis (live mode only)
OPENAI_API_KEY=

# Optional: model override for synthesis
OPENAI_MODEL=gpt-4o

# Optional: NCBI E-utilities etiquette (PubMed live mode)
NCBI_EMAIL=
NCBI_API_KEY=

# Optional: rate-limit tuning for live connectors
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
